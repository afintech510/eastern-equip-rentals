# Eastern Rentals — environment template.
# Secrets are sourced at runtime via Doppler (owner standard). NEVER commit a
# real .env. Copy to `.env` for local dev and fill placeholders, or let Doppler
# inject these in CI/prod.

# ── APP ───────────────────────────────────
NODE_ENV=production
ENVIRONMENT=development
NEXT_PUBLIC_BASE_URL=http://localhost:3009
NEXT_PUBLIC_API_URL=http://localhost:8009
WEB_ORIGIN=http://localhost:3009

# ── SUPABASE (managed cloud) ──────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhb...
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...

# ── REDIS (locks / jobs) ──────────────────
REDIS_URL=redis://redis:6379/0

# ── INTEGRATIONS (placeholders — wired in later phases) ──
# Stripe (Phase 02b)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Twilio SMS (Phase 04)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Email — Resend/Postmark (Phase 04)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# SignWell e-sign (Phase 03)
SIGNWELL_API_KEY=
# Google Distance Matrix (Phase 02b delivery pricing)
GOOGLE_DISTANCE_MATRIX_API_KEY=
